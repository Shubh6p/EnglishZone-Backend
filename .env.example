# ==========================================
# ENGLISH ZONE - BACKEND ENVIRONMENT VARIABLES
# ==========================================

# 1. Server Configuration
# ------------------------------------------
# The port your Node.js backend will listen on (default is usually 5000)
PORT=5000

# 2. Database Connection (MongoDB)
# ------------------------------------------
# The connection string for your MongoDB instance (e.g., MongoDB Atlas)
# Format: mongodb+srv://<username>:<password>@cluster0...
DATABASE_URL="mongodb+srv://dbuser:Surya1234@cluster0.td1kpmw.mongodb.net/?appName=Cluster0"

# 3. Security & Authentication (JWT)
# ------------------------------------------
# A long, random string used to sign JSON Web Tokens securely
JWT_SECRET="super-secret-key-change-me-in-production"
# How long until a user's session expires (e.g., "15m", "1h", "7d")
JWT_EXPIRES_IN="15m"

# 4. Push Notifications: SMS (Twilio) - Optional
# ------------------------------------------
# If left blank, the system will use the Mock Logger (Prints to terminal)
# TWILIO_ACCOUNT_SID="your_twilio_account_sid_here"
# TWILIO_AUTH_TOKEN="your_twilio_auth_token_here"
# TWILIO_PHONE_NUMBER="+1234567890"

# 5. Push Notifications: Email (SendGrid) - Optional
# ------------------------------------------
# If left blank, the system will use the Mock Logger (Prints to terminal)
# SENDGRID_API_KEY="your_sendgrid_api_key_here"
# SENDGRID_FROM_EMAIL="noreply@englishzone.com"
